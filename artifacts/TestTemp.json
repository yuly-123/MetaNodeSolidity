					"contents": "{\n\n    function cleanup_t_rational_213_by_1(value) -> cleaned {\n        cleaned := value\n    }\n\n    function cleanup_t_uint256(value) -> cleaned {\n        cleaned := value\n    }\n\n    function identity(value) -> ret {\n        ret := value\n    }\n\n    function convert_t_rational_213_by_1_to_t_uint256(value) -> converted {\n        converted := cleanup_t_uint256(identity(cleanup_t_rational_213_by_1(value)))\n    }\n\n    function abi_encode_t_rational_213_by_1_to_t_uint256_fromStack(value, pos) {\n        mstore(pos, convert_t_rational_213_by_1_to_t_uint256(value))\n    }\n\n    function abi_encode_tuple_t_rational_213_by_1__to_t_uint256__fromStack_reversed(headStart , value0) -> tail {\n        tail := add(headStart, 32)\n\n        abi_encode_t_rational_213_by_1_to_t_uint256_fromStack(value0,  add(headStart, 0))\n\n    }\n\n}\n",
